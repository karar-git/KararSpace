// Prisma schema for Portfolio
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Admin user for dashboard
model Admin {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Projects
model Project {
  id               String   @id @default(cuid())
  title            String
  slug             String   @unique
  shortDescription String?
  problem          String?
  approach         String?
  insights         String?
  mainImage        String?
  projectUrl       String?
  githubUrl        String?
  tags             String[] @default([])
  featured         Boolean  @default(false)
  published        Boolean  @default(false)
  publishedAt      DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

// Articles / Writing
model Article {
  id              String    @id @default(cuid())
  title           String
  slug            String    @unique
  summary         String?
  content         String?
  featuredImage   String?
  readingTime     Int?
  tags            String[]  @default([])
  published       Boolean   @default(false)
  publishedAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

// Certificates
model Certificate {
  id             String    @id @default(cuid())
  title          String
  issuer         String?
  credentialId   String?
  credentialLink String?
  issueDate      DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

// Research Papers
model Research {
  id                String    @id @default(cuid())
  title             String
  slug              String    @unique
  abstract          String?
  authors           String?
  journalConference String?
  paperUrl          String?
  publishedAt       DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
}

// Ideas / Quick Notes
model Idea {
  id          String    @id @default(cuid())
  title       String
  slug        String    @unique
  content     String?
  published   Boolean   @default(false)
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

// Life Content (Personal Blog)
model LifeContent {
  id          String    @id @default(cuid())
  title       String
  slug        String    @unique
  excerpt     String?
  content     String?
  coverImage  String?
  readingTime Int?
  published   Boolean   @default(false)
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

// Now Focus (What I'm doing now)
model NowFocus {
  id          String   @id @default(cuid())
  title       String
  description String?
  status      String?  @default("active")
  startDate   DateTime?
  endDate     DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Opportunities (shared opportunities for students/developers)
model Opportunity {
  id          String    @id @default(cuid())
  title       String
  description String?
  link        String?
  type        String?   // e.g., "internship", "scholarship", "competition", "program"
  deadline    DateTime?
  published   Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

// Site Settings (personal info, social links, etc.)
model SiteSettings {
  id          String   @id @default("main")
  name        String?
  title       String?
  bio         String?
  email       String?
  location    String?
  avatarUrl   String?
  socialLinks Json?    @default("[]")
  interests   Json?    @default("[]")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
